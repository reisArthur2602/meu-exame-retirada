# ──────────────────────────────────────────────
# Banco de dados (PostgreSQL via Prisma)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/meuexame

# ──────────────────────────────────────────────
# Autenticação JWT
# Gere com: openssl rand -base64 32
# ──────────────────────────────────────────────
JWT_SECRET=
NODE_ENV="development"

# ──────────────────────────────────────────────
# URL pública da aplicação
# Usado nos links enviados via WhatsApp
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://meuexame.com.br

# ──────────────────────────────────────────────
# Servidor FTP (armazenamento de laudos em PDF)
# ──────────────────────────────────────────────
FTP_HOST=ftp.seuservidor.com.br
FTP_USER=usuario_ftp
FTP_PASSWORD=
FTP_PORT=21
FTP_SECURE=false
FTP_BASE_DIR=/laudos
FTP_PUBLIC_URL=https://arquivos.seuservidor.com.br/laudos


SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
